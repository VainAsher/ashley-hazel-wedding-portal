# ===========================================================================
# Production deploy-time environment (Docker Compose) — wedding portal.
#
# This is the env that `deploy.sh` sources (production/.env) and Compose
# interpolates for the PRODUCTION stack. Copy this file to `production/.env` on
# the PRODUCTION host (a SEPARATE checkout from staging), fill the <SET ...>
# values from your secret store, and keep the real file OUT of git.
#
# In CI/GitHub deploys these are provided by the `production` GitHub Environment
# instead. Non-secret prod values (DB name, ports, URLs) are safe to commit as
# the template below; secrets are placeholders only.
# ===========================================================================

# --- Environment ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# --- Database — ISOLATED prod DB (data lives on the wedding-prod-pgdata volume) ---
POSTGRES_DB=wedding_prod
POSTGRES_USER=wedding
POSTGRES_PASSWORD=<SET: strong, unique production database password>

# --- Frontend host port ---
# Cloudflared + Traefik on infra-core (.23) route the public subdomain to this
# port on the wedding VM (.32). MUST differ from staging's :80.
FRONTEND_HOST_PORT=8090

# --- URLs / CORS (production config REQUIRES https + no localhost) ---
# Same-origin SPA: the frontend serves the app and proxies /api to the backend,
# so all three are the public subdomain.
API_URL=https://ashley-and.hazel-of-halifax.com
FRONTEND_URL=https://ashley-and.hazel-of-halifax.com
CORS_ORIGINS_RAW=https://ashley-and.hazel-of-halifax.com

# --- Secrets (>= 16 chars; injected at runtime, never baked into images) ---
JWT_SECRET=<SET>
API_KEY_SECRET=<SET>
SESSION_SECRET_KEY=<SET>
SESSION_COOKIE_SECURE=true
SESSION_MAX_AGE_SECONDS=2592000

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1
METRICS_ENABLED=true
